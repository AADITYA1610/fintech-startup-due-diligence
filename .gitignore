*.py[cod]
*$py.class

# Environment variables and secrets
.env
.env.*
!.env.example
.streamlit/secrets.toml

# IDE files
.vscode/
.idea/

# Operating system files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

