.pytest_cache/
.coverage
htmlcov/

# Build files
build/
dist/
*.egg-info/

# Model files
models/*.pkl
models/*.joblib
models/*.json
models/*.ubj

# Generated reports
reports/*.pdf
reports/*.docx

# Uploaded and processed data
data/raw/*
data/processed/*

